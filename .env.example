# =====================================================================
# V LIVING — ENVIRONMENT VARIABLES
# Copy this file to `.env.local` and fill in real values.
# NEVER commit `.env.local`. All keys below are placeholders.
# The MVP runs fully on mock data WITHOUT any of these set.
# =====================================================================

# ---------------------------------------------------------------------
# App
# ---------------------------------------------------------------------
NEXT_PUBLIC_APP_URL="https://v-living.vercel.app"
NEXT_PUBLIC_APP_NAME="V Living"

# ---------------------------------------------------------------------
# Authentication — Clerk  (https://clerk.com)
# ---------------------------------------------------------------------
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_xxxxxxxxxxxxxxxxxxxx"
CLERK_SECRET_KEY="sk_test_xxxxxxxxxxxxxxxxxxxx"
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"

# ---------------------------------------------------------------------
# Database — Neon PostgreSQL  (https://neon.tech)
# ---------------------------------------------------------------------
DATABASE_URL="postgresql://user:password@host.neon.tech/vliving?sslmode=require"

# ---------------------------------------------------------------------
# Email — Resend  (https://resend.com)
# ---------------------------------------------------------------------
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxx"
RESEND_FROM_EMAIL="hola@vliving.com"

# ---------------------------------------------------------------------
# Payments — Mercado Pago  (https://www.mercadopago.com.mx/developers)
# ---------------------------------------------------------------------
MERCADOPAGO_ACCESS_TOKEN="APP_USR-xxxxxxxxxxxxxxxxxxxx"
NEXT_PUBLIC_MERCADOPAGO_PUBLIC_KEY="APP_USR-xxxxxxxxxxxxxxxxxxxx"

# ---------------------------------------------------------------------
# Payments (optional) — Stripe  (https://stripe.com)
# ---------------------------------------------------------------------
STRIPE_SECRET_KEY="sk_test_xxxxxxxxxxxxxxxxxxxx"
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_xxxxxxxxxxxxxxxxxxxx"
STRIPE_WEBHOOK_SECRET="whsec_xxxxxxxxxxxxxxxxxxxx"

# ---------------------------------------------------------------------
# Maps — Google Maps  (https://console.cloud.google.com)
# ---------------------------------------------------------------------
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY="AIzaSyxxxxxxxxxxxxxxxxxxxx"

# ---------------------------------------------------------------------
# Communication — Twilio / WhatsApp  (https://twilio.com)
# ---------------------------------------------------------------------
TWILIO_ACCOUNT_SID="ACxxxxxxxxxxxxxxxxxxxx"
TWILIO_AUTH_TOKEN="xxxxxxxxxxxxxxxxxxxx"
TWILIO_WHATSAPP_FROM="whatsapp:+14155238886"

# ---------------------------------------------------------------------
# Flights — Duffel  (https://duffel.com)
# ---------------------------------------------------------------------
DUFFEL_ACCESS_TOKEN="duffel_test_xxxxxxxxxxxxxxxxxxxx"

# NOTE: RateHawk is intentionally NOT integrated in this build.
